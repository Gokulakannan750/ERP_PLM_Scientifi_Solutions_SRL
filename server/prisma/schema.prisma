generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                       Int                 @id @default(autoincrement())
  email                    String              @unique
  password                 String
  role                     String              @default("SUB_ADMIN")
  name                     String?
  isActive                 Boolean             @default(true)
  createdAt                DateTime            @default(now())
  updatedAt                DateTime            @updatedAt
  changeLogEntries         CompanyChangeLog[]  @relation("ChangeLogEntries")
  documentUploads          CompanyDocument[]   @relation("DocumentUploads")
  plmAuditLogs             PlmAuditLog[]       @relation("PlmAuditActor")
  checkedOutItems          Product[]           @relation("CheckedOutByUser")
  productVersions          Product[]           @relation("ProductVersions")
  productDocumentUploads   ProductDocument[]   @relation("ProductDocumentUploads")
  projectDocumentUploads   ProjectDocument[]   @relation("ProjectDocumentUploads")
  projectTeamMembers       ProjectTeamMember[]
  approvedPurchaseRequests PurchaseRequest[]   @relation("ApprovedPurchaseRequests")
  purchaseRequests         PurchaseRequest[]   @relation("PurchaseRequests")
  tasksOwned               Task[]              @relation("TaskOwner")
  taskComments             TaskComment[]
  timesheetEntries         TimesheetEntry[]    @relation("TimesheetEntries")
  permissions              UserPermission[]

  @@index([email])
  @@index([role])
  @@index([createdAt])
}

model Permission {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  description String?
  category    String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       UserPermission[]
}

model UserPermission {
  id           Int        @id @default(autoincrement())
  userId       Int
  permissionId Int
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
}

model ContactCategory {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  companies   Company[]
}

model Company {
  id                            Int                @id @default(autoincrement())
  name                          String
  website                       String?
  email                         String?
  phone                         String?
  taxId                         String?
  gstNumber                     String?
  vatPercentage                 Decimal?
  paymentTerms                  String?
  incoterms                     String?
  notes                         String?
  isObsolete                    Boolean            @default(false)
  categoryId                    Int?
  createdAt                     DateTime           @default(now())
  updatedAt                     DateTime           @updatedAt
  addresses                     Address[]
  bankAccounts                  BankAccount[]
  category                      ContactCategory?   @relation(fields: [categoryId], references: [id])
  changeLogs                    CompanyChangeLog[]
  documents                     CompanyDocument[]
  contacts                      Contact[]
  creditNotes                   CreditNote[]
  deliveryNotes                 DeliveryNote[]
  invoices                      Invoice[]
  offers                        Offer[]
  productsAsAlternativeSupplier Product[]          @relation("AlternativeSupplier")
  products                      Product[]
  projects                      Project[]
  purchaseRequests              PurchaseRequest[]
  stockBatches                  StockBatch[]

  @@index([name])
  @@index([categoryId])
  @@index([createdAt])
  @@index([isObsolete])
}

model Address {
  id          Int       @id @default(autoincrement())
  type        String?
  street      String?
  street2     String?
  houseNumber String?
  city        String?
  state       String?
  pincode     String?
  country     String?
  companyId   Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contacts    Contact[]
}

model Contact {
  id         Int      @id @default(autoincrement())
  name       String
  firstName  String?
  surname    String?
  email      String?
  pecEmail   String?
  phone      String?
  cellPhone  String?
  jobTitle   String?
  notes      String?
  quickNotes String?
  isObsolete Boolean  @default(false)
  companyId  Int
  addressId  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  address    Address? @relation(fields: [addressId], references: [id])
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([isObsolete])
}

model BankAccount {
  id            Int      @id @default(autoincrement())
  companyId     Int
  bankName      String
  accountNumber String?
  iban          String?
  bicSwift      String?
  routingNumber String?
  bankAddress   String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model CompanyDocument {
  id               Int      @id @default(autoincrement())
  companyId        Int
  fileName         String
  originalFileName String
  fileUrl          String
  fileSize         Int?
  mimeType         String?
  version          Int      @default(1)
  uploadedByUserId Int
  createdAt        DateTime @default(now())
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  uploadedBy       User     @relation("DocumentUploads", fields: [uploadedByUserId], references: [id])

  @@index([companyId])
}

model CompanyChangeLog {
  id        Int      @id @default(autoincrement())
  companyId Int
  userId    Int
  fieldName String
  oldValue  String?
  newValue  String?
  changedAt DateTime @default(now())
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User     @relation("ChangeLogEntries", fields: [userId], references: [id])

  @@index([companyId])
  @@index([changedAt])
}

model Product {
  id                               Int               @id @default(autoincrement())
  sku                              String
  name                             String
  description                      String?
  price                            Decimal
  quantity                         Int               @default(0)
  reserved                         Int               @default(0)
  minLevel                         Int               @default(5)
  maxLevel                         Int               @default(100)
  categoryCode                     String?
  subcategoryCode                  String?
  skuCounter                       Int?
  plmType                          String?           @default("P")
  itemNumber                       String?
  revision                         String?           @default("A")
  lifecycleState                   String            @default("IN_WORK")
  isLocked                         Boolean           @default(false)
  isObsolete                       Boolean           @default(false)
  cadTool                          String            @default("NONE")
  drawingSequence                  Int?
  drawingRevision                  String?
  checkedOutByUserId               Int?
  checkedOutAt                     DateTime?
  checkoutNote                     String?
  parentId                         Int?
  brand                            String?
  itemType                         String?
  unitOfMeasure                    String?
  currency                         String?           @default("USD")
  importDutyPercentage             Decimal?
  shippingCostPerItem              Decimal?
  alternativeSupplierId            Int?
  primarySupplierArticleNumber     String?
  alternativeSupplierArticleNumber String?
  reorderQuantity                  Int?
  reorderTriggerThreshold          Int?              @default(5)
  leadTimeDays                     Int?
  supplierQuoteReference           String?
  hsCode                           String?
  storageFacility                  String?
  storageWarehouse                 String?
  storageShelf                     String?
  storageBin                       String?
  lastStockCheckDate               DateTime?
  barcodeQrData                    String?
  plmItemLink                      String?
  vaultFileName                    String?
  vaultVersion                     Int               @default(0)
  folderId                         Int?
  supplierId                       Int?
  materialId                       Int?
  recDate                          DateTime          @default(now())
  lastRecID                        Int?
  modifiedByUserId                 Int
  isLatest                         Boolean           @default(true)
  createdAt                        DateTime          @default(now())
  updatedAt                        DateTime          @updatedAt
  usedInBoms                       BomItem[]         @relation("ChildProduct")
  bomItems                         BomItem[]         @relation("ParentProduct")
  invoiceItems                     InvoiceItem[]
  offerItems                       OfferItem[]
  auditLogs                        PlmAuditLog[]
  alternativeSupplier              Company?          @relation("AlternativeSupplier", fields: [alternativeSupplierId], references: [id])
  checkedOutBy                     User?             @relation("CheckedOutByUser", fields: [checkedOutByUserId], references: [id])
  material                         PlmMaterial?      @relation(fields: [materialId], references: [id])
  modifiedBy                       User              @relation("ProductVersions", fields: [modifiedByUserId], references: [id])
  parentItem                       Product?          @relation("ItemDrawings", fields: [parentId], references: [id])
  drawings                         Product[]         @relation("ItemDrawings")
  supplier                         Company?          @relation(fields: [supplierId], references: [id])
  folder                           PlmFolder?        @relation(fields: [folderId], references: [id])
  documents                        ProductDocument[]
  purchaseRequests                 PurchaseRequest[]
  batches                          StockBatch[]
  movements                        StockMovement[]

  @@index([sku])
  @@index([name])
  @@index([quantity])
  @@index([supplierId])
  @@index([alternativeSupplierId])
  @@index([isLatest])
  @@index([lastRecID])
  @@index([categoryCode])
  @@index([isObsolete])
  @@index([lifecycleState])
  @@index([plmType])
}

model BomItem {
  id        Int      @id @default(autoincrement())
  parentId  Int
  childId   Int
  quantity  Decimal  @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  child     Product  @relation("ChildProduct", fields: [childId], references: [id], onDelete: Cascade)
  parent    Product  @relation("ParentProduct", fields: [parentId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
}

model PlmCounter {
  id         Int      @id @default(1)
  lastNumber Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model PlmFolder {
  id        Int         @id @default(autoincrement())
  name      String
  parentId  Int?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  parent    PlmFolder?  @relation("FolderTree", fields: [parentId], references: [id])
  children  PlmFolder[] @relation("FolderTree")
  items     Product[]

  @@index([parentId])
}

model PlmAuditLog {
  id        Int      @id @default(autoincrement())
  productId Int
  userId    Int
  action    String
  fromState String?
  toState   String?
  note      String?
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation("PlmAuditActor", fields: [userId], references: [id])

  @@index([productId])
  @@index([userId])
  @@index([createdAt])
}

model PlmMaterial {
  id        Int       @id @default(autoincrement())
  name      String
  colour    String?
  texture   String?
  density   Float?
  standard  String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]

  @@index([name])
}

model PlmTemplate {
  id          Int      @id @default(autoincrement())
  itemType    String
  name        String
  filePath    String?
  fileExt     String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([itemType, isActive])
  @@index([itemType])
}

model ProductDocument {
  id               Int      @id @default(autoincrement())
  productId        Int
  fileName         String
  originalFileName String
  fileUrl          String
  fileSize         Int?
  mimeType         String?
  version          Int      @default(1)
  documentType     String   @default("GENERAL")
  uploadedByUserId Int
  createdAt        DateTime @default(now())
  product          Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  uploadedBy       User     @relation("ProductDocumentUploads", fields: [uploadedByUserId], references: [id])

  @@index([productId])
}

model StockBatch {
  id           Int      @id @default(autoincrement())
  productId    Int
  batchNumber  String?
  lotNumber    String?
  serialNumber String?
  quantity     Int      @default(0)
  currentQty   Int      @default(0)
  supplierId   Int?
  receivedAt   DateTime @default(now())
  product      Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier     Company? @relation(fields: [supplierId], references: [id])

  @@index([productId])
  @@index([batchNumber])
  @@index([serialNumber])
}

model PurchaseRequest {
  id                  Int                       @id @default(autoincrement())
  requestNumber       String                    @unique
  direction           String                    @default("OUTBOUND")
  type                String                    @default("INVENTORY")
  productId           Int?
  freeTextDescription String?
  quantity            Decimal
  unitOfMeasure       String?                   @default("units")
  estimatedUnitPrice  Decimal?
  totalEstimatedCost  Decimal?
  requiredByDate      DateTime?
  projectId           Int?
  companyId           Int?
  priority            String                    @default("MEDIUM")
  status              String                    @default("RAISED")
  purchaseOrderNumber String?
  actualUnitPrice     Decimal?
  actualTotalCost     Decimal?
  receivedQuantity    Decimal?
  notes               String?
  requestedByUserId   Int?
  approvedByUserId    Int?
  requestedAt         DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  approvedBy          User?                     @relation("ApprovedPurchaseRequests", fields: [approvedByUserId], references: [id])
  company             Company?                  @relation(fields: [companyId], references: [id])
  product             Product?                  @relation(fields: [productId], references: [id])
  project             Project?                  @relation(fields: [projectId], references: [id])
  requestedBy         User?                     @relation("PurchaseRequests", fields: [requestedByUserId], references: [id])
  documents           PurchaseRequestDocument[]

  @@index([status])
  @@index([direction])
  @@index([productId])
  @@index([companyId])
  @@index([projectId])
  @@index([priority])
}

model PurchaseRequestDocument {
  id                Int             @id @default(autoincrement())
  purchaseRequestId Int
  fileName          String
  originalFileName  String
  fileUrl           String
  fileSize          Int?
  mimeType          String?
  uploadedByUserId  Int
  createdAt         DateTime        @default(now())
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)

  @@index([purchaseRequestId])
}

model DeliveryNote {
  id               Int                    @id @default(autoincrement())
  deliveryNumber   String                 @unique
  companyId        Int
  invoiceId        Int?
  projectId        Int?
  status           String                 @default("DRAFT")
  deliveryDate     DateTime?
  shippedAt        DateTime?
  deliveredAt      DateTime?
  customerPoNumber String?
  customerPoDate   DateTime?
  carrier          String?
  trackingNumber   String?
  incoterms        String?
  packageType      String?
  packageCount     Int?
  weightKg         Decimal?
  dimensionL       Decimal?
  dimensionW       Decimal?
  dimensionH       Decimal?
  deliveryAddress  String?
  notes            String?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  company          Company                @relation(fields: [companyId], references: [id])
  invoice          Invoice?               @relation(fields: [invoiceId], references: [id])
  project          Project?               @relation(fields: [projectId], references: [id])
  documents        DeliveryNoteDocument[]
  items            DeliveryNoteItem[]

  @@index([status])
  @@index([companyId])
  @@index([invoiceId])
  @@index([trackingNumber])
  @@index([projectId])
}

model DeliveryNoteItem {
  id             Int          @id @default(autoincrement())
  deliveryNoteId Int
  lineNumber     Int
  productId      Int?
  sku            String?
  description    String
  quantity       Decimal
  unitOfMeasure  String?      @default("units")
  createdAt      DateTime     @default(now())
  deliveryNote   DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)

  @@index([deliveryNoteId])
}

model DeliveryNoteDocument {
  id               Int          @id @default(autoincrement())
  deliveryNoteId   Int
  fileName         String
  originalFileName String
  fileUrl          String
  fileSize         Int?
  mimeType         String?
  documentType     String?
  uploadedByUserId Int
  createdAt        DateTime     @default(now())
  deliveryNote     DeliveryNote @relation(fields: [deliveryNoteId], references: [id], onDelete: Cascade)

  @@index([deliveryNoteId])
}

model ProductCategory {
  id            Int                  @id @default(autoincrement())
  code          String               @unique
  name          String
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt
  subcategories ProductSubcategory[]
}

model ProductSubcategory {
  id         Int             @id @default(autoincrement())
  code       String
  name       String
  categoryId Int
  createdAt  DateTime        @default(now())
  category   ProductCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, code])
}

model StockMovement {
  id        Int      @id @default(autoincrement())
  type      String
  quantity  Int
  reason    String?
  productId Int
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Project {
  id               Int                 @id @default(autoincrement())
  name             String
  description      String?
  category         String?
  tags             String?
  priorityLevel    String              @default("MEDIUM")
  budget           Decimal?
  status           String              @default("PLANNING")
  startDate        DateTime?
  endDate          DateTime?
  clientId         Int?
  cadFilePath      String?
  isPublic         Boolean             @default(true)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  deliveryNotes    DeliveryNote[]
  invoices         Invoice[]
  milestones       Milestone[]
  client           Company?            @relation(fields: [clientId], references: [id])
  documents        ProjectDocument[]
  teamMembers      ProjectTeamMember[]
  purchaseRequests PurchaseRequest[]
  tasks            Task[]

  @@index([status])
  @@index([clientId])
  @@index([createdAt])
}

model ProjectTeamMember {
  id        Int      @id @default(autoincrement())
  projectId Int
  userId    Int
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
}

model Milestone {
  id         Int       @id @default(autoincrement())
  projectId  Int
  name       String
  targetDate DateTime?
  isReached  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks      Task[]

  @@index([projectId])
}

model Task {
  id                        Int              @id @default(autoincrement())
  projectId                 Int
  milestoneId               Int?
  ownerId                   Int?
  title                     String
  description               String?
  startDate                 DateTime?
  dueDate                   DateTime?
  priority                  String           @default("MEDIUM")
  status                    String           @default("OPEN")
  estimatedHours            Decimal?
  actualHours               Decimal?         @default(0)
  createdAt                 DateTime         @default(now())
  updatedAt                 DateTime         @updatedAt
  milestone                 Milestone?       @relation(fields: [milestoneId], references: [id])
  owner                     User?            @relation("TaskOwner", fields: [ownerId], references: [id])
  project                   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments                  TaskComment[]
  dependenciesAsPredecessor TaskDependency[] @relation("PredecessorTask")
  dependenciesAsSuccessor   TaskDependency[] @relation("SuccessorTask")
  timesheets                TimesheetEntry[]

  @@index([projectId])
  @@index([milestoneId])
  @@index([ownerId])
  @@index([status])
}

model TaskDependency {
  id            Int      @id @default(autoincrement())
  predecessorId Int
  successorId   Int
  createdAt     DateTime @default(now())
  predecessor   Task     @relation("PredecessorTask", fields: [predecessorId], references: [id], onDelete: Cascade)
  successor     Task     @relation("SuccessorTask", fields: [successorId], references: [id], onDelete: Cascade)

  @@unique([predecessorId, successorId])
}

model TaskComment {
  id        Int      @id @default(autoincrement())
  taskId    Int
  userId    Int
  content   String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
}

model TimesheetEntry {
  id        Int      @id @default(autoincrement())
  taskId    Int
  userId    Int
  date      DateTime
  hours     Decimal
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation("TimesheetEntries", fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([userId])
  @@index([date])
}

model ProjectDocument {
  id               Int      @id @default(autoincrement())
  projectId        Int
  fileName         String
  originalFileName String
  fileUrl          String
  fileSize         Int?
  mimeType         String?
  version          Int      @default(1)
  uploadedByUserId Int
  createdAt        DateTime @default(now())
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy       User     @relation("ProjectDocumentUploads", fields: [uploadedByUserId], references: [id])

  @@index([projectId])
}

model Invoice {
  id              Int            @id @default(autoincrement())
  invoiceNumber   String         @unique
  companyId       Int
  offerId         Int?           @unique
  totalAmount     Decimal
  taxRate         Decimal        @default(0)
  discountPercent Decimal?       @default(0)
  discountAmount  Decimal?       @default(0)
  status          String         @default("UNPAID")
  date            DateTime       @default(now())
  dueDate         DateTime?
  notes           String?
  poNumber        String?
  poDate          DateTime?
  paymentMethod   String?
  paymentDate     DateTime?
  projectId       Int?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  creditNotes     CreditNote[]
  deliveryNotes   DeliveryNote[]
  company         Company        @relation(fields: [companyId], references: [id])
  offer           Offer?         @relation(fields: [offerId], references: [id])
  project         Project?       @relation(fields: [projectId], references: [id])
  items           InvoiceItem[]

  @@index([companyId])
  @@index([status])
  @@index([dueDate])
  @@index([createdAt])
  @@index([projectId])
}

model InvoiceItem {
  id              Int      @id @default(autoincrement())
  invoiceId       Int
  productId       Int?
  description     String
  quantity        Int
  unitPrice       Decimal
  discountPercent Decimal? @default(0)
  vatPercent      Decimal? @default(0)
  totalPrice      Decimal
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product         Product? @relation(fields: [productId], references: [id])
}

model Offer {
  id              Int         @id @default(autoincrement())
  offerNumber     String      @unique
  companyId       Int
  totalAmount     Decimal
  taxRate         Decimal     @default(0)
  status          String      @default("DRAFT")
  validUntil      DateTime?
  description     String?
  version         Int         @default(1)
  rejectionReason String?
  parentOfferId   Int?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  invoice         Invoice?
  company         Company     @relation(fields: [companyId], references: [id])
  items           OfferItem[]

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model OfferItem {
  id              Int      @id @default(autoincrement())
  offerId         Int
  productId       Int?
  description     String
  quantity        Int
  unitPrice       Decimal
  discountPercent Decimal? @default(0)
  totalPrice      Decimal
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  offer           Offer    @relation(fields: [offerId], references: [id], onDelete: Cascade)
  product         Product? @relation(fields: [productId], references: [id])
}

model CreditNote {
  id               Int              @id @default(autoincrement())
  creditNoteNumber String           @unique
  invoiceId        Int
  companyId        Int
  reason           String?
  status           String           @default("DRAFT")
  totalAmount      Decimal          @default(0)
  issuedAt         DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  company          Company          @relation(fields: [companyId], references: [id])
  invoice          Invoice          @relation(fields: [invoiceId], references: [id])
  items            CreditNoteItem[]

  @@index([invoiceId])
  @@index([companyId])
  @@index([status])
}

model CreditNoteItem {
  id           Int        @id @default(autoincrement())
  creditNoteId Int
  description  String
  quantity     Int        @default(1)
  unitPrice    Decimal    @default(0)
  totalPrice   Decimal    @default(0)
  productId    Int?
  createdAt    DateTime   @default(now())
  creditNote   CreditNote @relation(fields: [creditNoteId], references: [id], onDelete: Cascade)
}

model Settings {
  id                 Int      @id @default(autoincrement())
  dateFormat         String   @default("DD/MM/YYYY")
  timeFormat         String   @default("HH:mm")
  emailTemplates     String
  invoiceTemplates   String?
  offerTemplates     String?
  companyName        String?
  companyAddress     String?
  companyPhone       String?
  companyCountryCode String?  @default("+91")
  companyEmail       String?
  isDefault          Boolean  @unique @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
