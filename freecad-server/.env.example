# Path to the FreeCAD lib directory that contains FreeCAD.so / FreeCAD.pyd
# Windows example: C:/Program Files/FreeCAD 1.0/bin
# Linux example:   /usr/lib/freecad/lib
FREECAD_LIB_PATH=

# Port the bridge server listens on (default 7474)
FREECAD_SERVER_PORT=7474

# Comma-separated origins allowed by CORS (match your Next.js dev port)
CORS_ORIGINS=http://localhost:3000

# Set to 1 to enable Flask debug mode (development only)
FLASK_DEBUG=0
